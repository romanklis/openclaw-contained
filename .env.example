# OpenClaw Contained — Environment Configuration
# Copy this file to .env and adjust values as needed.

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_PASSWORD=openclaw_pass

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# =============================================================================
# LLM PROVIDERS
# =============================================================================
# URL where Ollama is reachable from Docker containers.
# On Linux with Ollama running on the host use: http://host.docker.internal:11434
OLLAMA_URL=http://host.docker.internal:11434

# Optional — set keys for the providers you want to use.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ============================================================================== 
# AGENT EXECUTION ENVIRONMENT (SANDBOX) 
# ============================================================================== 
# WARNING: Running AI agents in standard Docker-in-Docker (DinD) is DANGEROUS  
# for production. It requires privileged mode, meaning a compromised agent  
# can potentially gain root access to the host machine.
#
# Available Options:
#   - gvisor          : (RECOMMENDED) Uses runsc for strict user-space kernel  
#                       isolation. Requires gVisor installed on the host.
#   - insecure-dind   : Standard Docker container. Easy for local testing,  
#                       but strictly NOT recommended for public/production use.
#   - dedicated-vm    : (Future) Spawns isolated Firecracker microVMs.
# 
AGENT_SANDBOX_MODE=insecure-dind

# =============================================================================
# FRONTEND
# =============================================================================
# API base URL the browser uses to reach the control-plane.
# Override when deploying behind a reverse-proxy or on a remote host.
API_URL=http://localhost:8000
